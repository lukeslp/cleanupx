class FinanceAnalyzer(BaseTool):
    """Tool for analyzing financial assets and market data."""
    
    def __init__(self):
        super().__init__()
        self.base_urls = {
            'stock': 'https://query1.finance.yahoo.com/v8/finance/chart/',
            'crypto': 'https://api.coingecko.com/api/v3/simple/price'
        }
```

