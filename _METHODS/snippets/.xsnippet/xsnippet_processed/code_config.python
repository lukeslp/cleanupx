XAI_MODEL_TEXT = os.getenv("XAI_MODEL_TEXT", "grok-3-mini-latest")
XAI_MODEL_VISION = os.getenv("XAI_MODEL_VISION", "grok-2-vision-latest")

# File Paths
CACHE_FILE = "generated_alts.json"
RENAME_LOG_FILE = "rename_log.json"

# File Extensions
