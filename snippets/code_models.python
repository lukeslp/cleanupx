# models (Code)

**File:** storage/models.py  
**Language:** Python  
**Lines:** 182  

**Description:** **: This module is a Python script that manages AI model metadata. It includes functions to categorize models by ID, fetch model details like size and descriptions, list local models from a server endpoint, and generate a JavaScript file for frontend use. The primary purpose is to organize and process model information for applications involving AI models, such as categorizing them into groups like "Dreamwalker Models" or "Vision Models", and outputting structured data.

```python
import requests
import json
from typing import Dict, List, Optional

def get_model_category(model_id: str) -> str:
    """Determine the category for a model based on its ID."""
    model_id = model_id.lower()
    
    if any(x in model_id for x in ['drummer-', 'camina']):
        return "Dreamwalker Models"
    elif any(x in model_id for x in ['vision', 'llava', 'bakllava', 'minicpm-v', 'moondream']):
        return "Vision Models"
    elif any(x in model_id for x in ['code', 'starcoder', 'opencoder']):
        return "Code Models"
    elif 'llama' in model_id:
        return "Llama Models"
    elif 'mistral' in model_id:
        return "Mistral Models"
    elif any(x in model_id for x in ['smollm', 'phi', 'nemotron-mini']):
        return "Small & Fast Models"
    elif any(x in model_id for x in ['impossible', 'falcon', 'dolphin', 'gemma']):
        return "Experimental Models"
    elif any(x in model_id for x in ['deepseek', 'granite', 'olmo']):
        return "Foundation Models"
   
